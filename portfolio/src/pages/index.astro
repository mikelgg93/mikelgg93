---
import { Image } from "astro:assets";
import Resume from "public/resume.json";
import CitationsData from "public/citations.json";
import Layout from "@/layouts/Layout.astro";
import CitationsChart from "@/components/CitationsChart";
import { getCollection } from "astro:content";
import { Clock } from "lucide-react";

const { name, summary } = Resume.basics;

const posts = await getCollection("blog");
const sortedPosts = posts
  .filter((p) => !p.data.lang || p.data.lang === "en")
  .sort(
    (a, b) =>
      new Date(b.data.date || 0).valueOf() -
      new Date(a.data.date || 0).valueOf(),
  )
  .slice(0, 3);
---

<Layout title={name} description={summary}>
  <header
    class="relative w-full h-[50vh] min-h-[450px] overflow-hidden flex items-end"
  >
    <img
      alt="Hero landscape"
      class="absolute inset-0 w-full h-full object-cover object-[center_35%]"
      src="/hero.png"
    />
    <div
      class="absolute inset-0 bg-gradient-to-b from-background/80 via-transparent to-background z-10"
    >
    </div>
    <div class="relative w-full max-w-5xl mx-auto px-4 md:px-8 pb-8 z-20 pt-24">
      <div class="max-w-3xl">
        <span
          class="uppercase tracking-[0.3em] text-tertiary-foreground bg-tertiary px-3 py-1 rounded-md mb-3 inline-block font-bold text-sm dark:bg-tertiary/80"
        >
          Vision Scientist
        </span>
        <h1
          class="text-4xl md:text-6xl font-extrabold text-foreground tracking-tighter leading-none mb-3 md:mb-4 font-[family-name:--font-display]"
        >
          {name}
        </h1>
        <p
          class="text-lg md:text-xl text-foreground/90 leading-relaxed max-w-xl font-light border-l-2 border-primary/50 pl-6"
        >
          {summary}
        </p>
      </div>
    </div>
  </header>

  <main class="pt-10 pb-16 px-4 md:px-6 max-w-5xl mx-auto space-y-16">
    <section class="max-w-3xl">
      <div class="flex items-center gap-4 mb-4">
        <h2 class="text-2xl font-bold text-foreground font-serif">About</h2>
        <div class="h-[1px] flex-grow bg-border opacity-50"></div>
      </div>
      <div
        class="prose dark:prose-invert prose-base max-w-none text-muted-foreground leading-relaxed"
      >
        {Resume.basics.about.split("\n\n").map((p) => <p>{p}</p>)}
      </div>
    </section>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">
      <section class="md:col-span-7 md:row-span-2">
        <div class="flex items-center gap-4 mb-8">
          <h2 class="text-2xl font-bold text-foreground font-serif">
            Curriculum Vitae
          </h2>
          <div class="h-[1px] flex-grow bg-border opacity-50"></div>
        </div>

        <div
          class="border-l-2 border-border/50 ml-3 sm:ml-5 flex flex-col gap-8 sm:gap-10 mt-6"
        >
          {
            Resume.work.map((job, i) => (
              <div
                class={`relative pl-8 sm:pl-12 experience-item ${i > 3 ? "hidden" : ""}`}
              >
                <div class="absolute -left-[21px] top-0 w-10 h-10 bg-white border-2 border-primary rounded-full z-10 flex items-center justify-center overflow-hidden shrink-0 shadow-sm p-0.5">
                  {job.url ? (
                    <a
                      href={job.url}
                      target="_blank"
                      rel="noreferrer"
                      class="w-full h-full flex items-center justify-center"
                    >
                      {job.logo && (
                        <img
                          src={job.logo}
                          alt={job.name}
                          class="w-full h-full object-contain hover:scale-110 transition-transform"
                        />
                      )}
                    </a>
                  ) : (
                    job.logo && (
                      <img
                        src={job.logo}
                        alt={job.name}
                        class="w-full h-full object-contain"
                      />
                    )
                  )}
                </div>

                {i === 0 && (
                  <div class="absolute -left-[5.5rem] top-2 flex flex-col items-center hidden sm:flex">
                    <span class="text-[10px] font-bold uppercase tracking-tighter text-primary bg-primary/20 px-1 py-0.5 rounded-sm">
                      Active
                    </span>
                  </div>
                )}

                <div class="flex flex-col pt-1 w-full">
                  <div class="flex flex-col sm:flex-row sm:items-baseline justify-between gap-1 mb-1">
                    <h3 class="text-lg font-bold text-foreground tracking-tight leading-snug uppercase">
                      {job.position}
                    </h3>
                    <span class="text-[10px] font-mono uppercase tracking-widest text-muted-foreground shrink-0 sm:ml-4">
                      {job.startDate} — {job.endDate}
                    </span>
                  </div>
                  <p class="text-sm font-medium text-primary mb-2">
                    {job.url ? (
                      <a
                        href={job.url}
                        target="_blank"
                        rel="noreferrer"
                        class="hover:underline"
                      >
                        {job.name}
                      </a>
                    ) : (
                      job.name
                    )}
                  </p>
                  <p class="text-muted-foreground leading-relaxed text-sm whitespace-pre-wrap max-w-2xl">
                    {job.summary}
                  </p>
                  {job.subRoles && job.subRoles.length > 0 && (
                    <ul class="mt-3 flex flex-col gap-2">
                      {job.subRoles.map((sub: any) => (
                        <li class="flex items-start gap-3 text-sm text-muted-foreground">
                          {sub.logo ? (
                            <img
                              src={sub.logo}
                              class="w-5 h-5 object-contain shrink-0 mt-0.5"
                            />
                          ) : (
                            <div class="w-5 h-5 shrink-0 bg-muted rounded-sm mt-0.5" />
                          )}
                          <span class="leading-snug">{sub.text}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </div>
            ))
          }
        </div>
        {
          Resume.work.length > 4 && (
            <button
              id="expand-cv"
              class="mt-12 ml-12 sm:ml-16 text-sm font-bold uppercase tracking-widest text-primary hover:underline underline-offset-4 flex items-center gap-2 cursor-pointer transition-colors"
            >
              <span>Show full history</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="transition-transform duration-300"
              >
                <path d="m6 9 6 6 6-6" />
              </svg>
            </button>
          )
        }
      </section>

      <section
        class="order-3 md:order-1 md:col-span-5 md:col-start-8 flex flex-col"
      >
        <div class="flex items-center gap-4 mb-8">
          <h2 class="text-2xl font-bold text-foreground font-serif">Blog</h2>
          <div class="h-[1px] flex-grow bg-border opacity-50"></div>
        </div>

        <div class="flex flex-col gap-3">
          {
            sortedPosts.map((post) => (
              <a
                href={`/blog/${post.id}`}
                class="block p-6 bg-muted/30 hover:bg-muted/60 transition-colors group relative overflow-hidden rounded-xl border border-transparent hover:border-border/50"
              >
                <div class="flex justify-between items-start mb-3">
                  <span class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground opacity-80">
                    {new Date(post.data.date || Date.now()).toLocaleDateString(
                      "en-US",
                      { year: "numeric", month: "short", day: "numeric" },
                    )}
                  </span>
                  <div class="flex items-center gap-1.5 text-primary">
                    <Clock className="w-3.5 h-3.5" />
                    <span class="text-[10px] font-bold uppercase tracking-widest">
                      {Math.max(
                        1,
                        Math.ceil((post.body || "").split(/\s+/).length / 200),
                      )}{" "}
                      min read
                    </span>
                  </div>
                </div>
                <h4 class="text-lg font-bold text-foreground leading-snug group-hover:text-primary transition-colors mb-2 font-serif">
                  {post.data.title}
                </h4>
                <p class="text-sm text-muted-foreground line-clamp-2 font-light">
                  {post.data.description}
                </p>
              </a>
            ))
          }

          <div class="mt-4 border-l border-border/50 pl-6 py-4">
            <p
              class="text-[11px] font-mono text-muted-foreground uppercase tracking-tighter mb-2"
            >
              SYSTEM STATUS // FEED
            </p>
            <div class="flex items-center gap-2">
              <div class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse">
              </div>
              <span class="text-xs font-semibold text-foreground"
                >Updating Lab Journal</span
              >
            </div>
          </div>
        </div>
      </section>

      <section
        class="order-2 md:order-2 md:col-span-5 md:col-start-8 flex flex-col justify-end mt-4 md:mt-0"
      >
        <div class="flex items-center gap-4 mb-8">
          <h2 class="text-2xl font-bold text-foreground font-serif">
            Education
          </h2>
          <div class="h-[1px] flex-grow bg-border opacity-50"></div>
        </div>

        <div
          class="border-l-2 border-border/50 ml-3 sm:ml-5 flex flex-col gap-6 mt-4"
        >
          {
            Resume.education.map((edu) => (
              <div class="relative pl-8 sm:pl-12">
                <div class="absolute -left-[21px] top-0 w-10 h-10 bg-white border-2 border-primary rounded-full z-10 flex items-center justify-center overflow-hidden shrink-0 shadow-sm p-0.5">
                  {edu.url ? (
                    <a
                      href={edu.url}
                      target="_blank"
                      rel="noreferrer"
                      class="w-full h-full flex items-center justify-center"
                    >
                      {edu.logo && (
                        <img
                          src={edu.logo}
                          alt={edu.institution}
                          class="w-full h-full object-contain hover:scale-110 transition-transform"
                        />
                      )}
                    </a>
                  ) : (
                    edu.logo && (
                      <img
                        src={edu.logo}
                        alt={edu.institution}
                        class="w-full h-full object-contain"
                      />
                    )
                  )}
                </div>
                <div class="flex flex-col pt-1 w-full">
                  <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-2 mb-1">
                    <h3 class="text-base font-bold text-foreground tracking-tight leading-snug uppercase max-w-lg">
                      {edu.studyType}
                    </h3>
                    {edu.level && (
                      <span class="text-[10px] font-mono text-muted-foreground uppercase tracking-widest whitespace-nowrap shrink-0 sm:ml-4">
                        {edu.level}
                      </span>
                    )}
                  </div>
                  <div class="flex flex-col sm:flex-row sm:items-baseline justify-between gap-1 mb-2">
                    <span class="text-sm font-medium text-primary">
                      {edu.url ? (
                        <a
                          href={edu.url}
                          target="_blank"
                          rel="noreferrer"
                          class="hover:underline"
                        >
                          {edu.institution}
                        </a>
                      ) : (
                        edu.institution
                      )}
                    </span>
                    <span class="text-[10px] font-mono text-muted-foreground uppercase tracking-widest shrink-0 sm:ml-4">
                      {edu.startDate} — {edu.endDate}
                    </span>
                  </div>
                  {edu.thesis && (
                    <p class="text-muted-foreground leading-relaxed text-sm whitespace-pre-wrap max-w-2xl mt-1">
                      {edu.thesis}
                    </p>
                  )}
                </div>
              </div>
            ))
          }
        </div>
      </section>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">
      <section class="md:col-span-7 flex flex-col">
        <div class="flex items-center gap-4 mb-8">
          <h2 class="text-2xl font-bold text-foreground font-serif">
            Publications
          </h2>
          <div class="h-[1px] flex-grow bg-border opacity-50"></div>
        </div>

        <div class="flex flex-col gap-5">
          {
            Resume.publications.map((pub, i) => (
              <div
                class={`pub-item relative pl-8 group transition-colors ${i > 3 ? "hidden" : ""}`}
              >
                <span class="absolute left-0 top-0 text-sm font-mono text-foreground font-semibold">
                  [{i + 1}]
                </span>
                <p class="text-sm text-foreground/90 leading-relaxed">
                  {pub.citation && pub.citation.includes(" URL ") ? (
                    <>
                      {pub.citation.split(" URL ")[0]} URL{" "}
                      <a
                        href={pub.url}
                        target="_blank"
                        rel="noreferrer"
                        class="text-primary hover:underline underline-offset-2 break-all"
                      >
                        {pub.citation.split(" URL ")[1]}
                      </a>
                    </>
                  ) : (
                    <a
                      href={pub.url}
                      target="_blank"
                      rel="noreferrer"
                      class="hover:text-primary transition-colors"
                    >
                      {pub.citation}
                    </a>
                  )}
                </p>
              </div>
            ))
          }
        </div>

        {
          Resume.publications.length > 4 && (
            <button
              id="expand-pubs"
              class="mt-8 text-sm font-bold uppercase tracking-widest text-primary hover:underline underline-offset-4 flex items-center gap-2 cursor-pointer transition-colors self-start"
            >
              <span>Show all publications</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="transition-transform duration-300"
              >
                <path d="m6 9 6 6 6-6" />
              </svg>
            </button>
          )
        }
      </section>

      <section class="md:col-span-5 flex flex-col">
        <div class="flex items-center gap-4 mb-8">
          <h2 class="text-2xl font-bold text-foreground font-serif">
            Citations
          </h2>
          <div class="h-[1px] flex-grow bg-border opacity-50"></div>
        </div>

        <div class="w-full flex flex-col items-center justify-center">
          <CitationsChart data={CitationsData.perYear} client:visible />
        </div>
      </section>
    </div>
  </main>

  <script>
    document.addEventListener("astro:page-load", () => {
      const expandBtn = document.getElementById("expand-cv");
      const experienceItems = document.querySelectorAll(".experience-item");
      if (expandBtn) {
        expandBtn.addEventListener("click", () => {
          experienceItems.forEach((item, i) => {
            if (i > 3) item.classList.toggle("hidden");
          });
          const isExpanded = !experienceItems[4]?.classList.contains("hidden");
          const span = expandBtn.querySelector("span");
          if (span)
            span.textContent = isExpanded ? "Show less" : "Show full history";
          const svg = expandBtn.querySelector("svg");
          if (svg)
            svg.style.transform = isExpanded
              ? "rotate(180deg)"
              : "rotate(0deg)";
        });
      }

      const expandPubsBtn = document.getElementById("expand-pubs");
      const pubItems = document.querySelectorAll(".pub-item");
      if (expandPubsBtn) {
        expandPubsBtn.addEventListener("click", () => {
          pubItems.forEach((item, i) => {
            if (i > 3) item.classList.toggle("hidden");
          });
          const isExpanded = !pubItems[4]?.classList.contains("hidden");
          const span = expandPubsBtn.querySelector("span");
          if (span)
            span.textContent = isExpanded
              ? "Show less"
              : "Show all publications";
          const svg = expandPubsBtn.querySelector("svg");
          if (svg)
            svg.style.transform = isExpanded
              ? "rotate(180deg)"
              : "rotate(0deg)";
        });
      }
    });
  </script>
</Layout>
