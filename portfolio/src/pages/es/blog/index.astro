---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { Clock } from "lucide-react";

const posts = await getCollection("blog");

const sortedPosts = posts
	.filter((p) => p.data.lang === "es")
	.sort(
		(a, b) =>
			new Date(b.data.date || 0).valueOf() -
			new Date(a.data.date || 0).valueOf(),
	);
---

<Layout title="Blog" description="Pensamientos sobre optometría, neurociencia y código.">
  <section class="container mx-auto px-4 py-12 md:py-24 max-w-screen-lg">
    <div class="flex flex-col items-start gap-4 mb-12 animate-in fade-in slide-in-from-bottom-6 duration-700">
      <h1 class="text-3xl font-bold tracking-tight md:text-5xl font-serif">Blog</h1>
      <p class="text-xl text-muted-foreground">
        Escribiendo sobre mi viaje en investigación y desarrollo.
      </p>
      <div class="h-[1px] w-full bg-border opacity-50 mt-4"></div>
    </div>

    <div
      class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 animate-in fade-in slide-in-from-bottom-8 duration-700 delay-200"
    >
      {
        sortedPosts.map((post) => (
          <a
            href={`/es/blog/${post.id.replace('-es', '')}`}
            class="block p-5 bg-muted/30 hover:bg-muted/60 transition-colors group relative overflow-hidden rounded-xl border border-transparent hover:border-border/50 flex flex-col h-full"
          >
              {post.data.image && (
                <div class="w-full h-48 mb-4 overflow-hidden rounded-lg bg-background shrink-0">
                  <Image inferSize={true} src={post.data.image} alt={post.data.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                </div>
              )}
              <div class="flex justify-between items-start mb-4">
                <span class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground opacity-80">
                  {new Date(post.data.date || Date.now()).toLocaleDateString("es-ES", { year: "numeric", month: "short", day: "numeric" })}
                </span>
                <div class="flex items-center gap-1.5 text-primary shrink-0 ml-2">
                  <Clock className="w-3.5 h-3.5" />
                  <span class="text-[10px] font-bold uppercase tracking-widest">{Math.max(1, Math.ceil((post.body || '').split(/\s+/).length / 200))} min read</span>
                </div>
              </div>
              <h4 class="text-xl font-bold text-foreground leading-snug group-hover:text-primary transition-colors mb-3 font-serif flex-grow">
                {post.data.title}
              </h4>
              <p class="text-sm text-muted-foreground line-clamp-3 font-light mt-auto">
                {post.data.description}
              </p>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
