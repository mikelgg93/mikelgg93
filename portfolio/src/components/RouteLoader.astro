---
import Signature from "@/components/Signature.astro";
---

<script is:inline>
  if (
    typeof sessionStorage !== "undefined" &&
    sessionStorage.getItem("signature_played") === "true"
  ) {
    document.documentElement.classList.add("skip-loader");
  }
</script>

<style is:global>
  html.skip-loader #route-loader {
    display: none !important;
  }
  html:not(.skip-loader) body {
    overflow: hidden;
  }
</style>

<div
  id="route-loader"
  class="fixed inset-0 h-[100dvh] w-screen z-[100] flex items-center justify-center bg-background transition-opacity duration-300 pointer-events-auto"
>
  <div class="w-64 md:w-80 h-auto text-foreground">
    <Signature />
  </div>
</div>

<script>
  let hasRun = false;

  document.addEventListener("astro:page-load", () => {
    const loader = document.getElementById("route-loader");

    const onSignatureDone = () => {
      if (document.body.contains(loader)) {
        loader.style.opacity = "0";
        loader.style.pointerEvents = "none";
        document.body.style.overflow = "";

        setTimeout(() => {
          if (document.body.contains(loader)) {
            loader.style.display = "none";
            sessionStorage.setItem("signature_played", "true");
            document.documentElement.classList.add("skip-loader");
          }
        }, 300);
      } else {
        document.body.style.overflow = "";
      }
    };

    document.addEventListener("signature:done", onSignatureDone);

    if (sessionStorage.getItem("signature_played") === "true" || hasRun) {
      if (loader) {
        loader.style.display = "none";
      }
      document.documentElement.classList.add("skip-loader");
      document.body.style.overflow = "";
      // Don't return here so we don't skip the keydown listener
    } else {
      hasRun = true;
    }
  });

  // Attach keydown globally outside the page-load event or outside the early return
  document.addEventListener("keydown", (e) => {
    if (e.key === "s" || e.key === "S") {
      const loader = document.getElementById("route-loader");
      if (loader) {
        loader.style.display = "flex";
        loader.style.opacity = "1";
        loader.style.pointerEvents = "auto";
        document.body.style.overflow = "hidden";
        document.documentElement.classList.remove("skip-loader");
        sessionStorage.setItem("signature_played", "false");
        document.dispatchEvent(new CustomEvent("signature:restart"));
      }
    }
  });
</script>
